# md-memo Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=10026

# Base path (change if deploying to a subpath)
BASE_PATH=/md-memo

# OpenRouter API Key (get yours at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Model to use for markdown formatting (via OpenRouter)
# Examples:
#   deepseek/deepseek-v4-flash  (fast, cheap)
#   anthropic/claude-3-5-sonnet  (high quality)
#   google/gemini-2.5-flash  (balanced)
AI_MODEL=deepseek/deepseek-v4-flash

# Model for the agent loop — MUST support tool/function calling. Falls back to AI_MODEL.
AGENT_MODEL=deepseek/deepseek-v4-pro

# Language for all agent output (BCP-47 tag). Default zh-TW (繁體中文).
AGENT_LANG=zh-TW

# Optional password protection (HTTP Basic Auth). Default OFF.
# Set AUTH_ENABLED=true plus a password to require login for the whole app and
# all APIs. Public permalink pages (/m/:id) stay open so shared links keep working.
# Enabling without a password is ignored (logs a warning, no protection).
AUTH_ENABLED=false
AUTH_PASSWORD=
